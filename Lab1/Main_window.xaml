<Window x:Class="MusicLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBlock HorizontalAlignment="Left" Margin="119,42,0,0" TextWrapping="Wrap" Text="Bands" VerticalAlignment="Top" FontSize="20"/>
        <TextBlock HorizontalAlignment="Left" Margin="485,42,0,0" TextWrapping="Wrap" Text="Band Information" VerticalAlignment="Top" FontSize="20"/>

        <Label Content="Genre" HorizontalAlignment="Left" Margin="119,80,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbGenre" HorizontalAlignment="Left" Margin="170,84,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="cbGenre_SelectionChanged"/>

        <ListBox x:Name="lbBands" HorizontalAlignment="Left" Height="225" Margin="119,120,0,0" VerticalAlignment="Top" Width="171" SelectionChanged="lbBands_SelectionChanged"/>

        <StackPanel Margin="485,100,50,0" VerticalAlignment="Top">
            <TextBlock x:Name="txtFormed" Text="Formed: "/>
            <TextBlock x:Name="txtMembers" Text="Members: " TextWrapping="Wrap"/>
        </StackPanel>

        <TextBlock HorizontalAlignment="Left" Margin="485,200,0,0" TextWrapping="Wrap" Text="Albums" VerticalAlignment="Top" FontSize="18"/>
        
        <ListBox x:Name="lbAlbums" HorizontalAlignment="Left" Height="100" Margin="485,230,0,0" VerticalAlignment="Top" Width="200"/>

        <Button Content="Save" HorizontalAlignment="Left" Margin="600,350,0,0" VerticalAlignment="Top" Width="75" Click="Save_Click"/>
    </Grid>
</Window>