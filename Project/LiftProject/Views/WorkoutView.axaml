<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LiftProject.ViewModels"
             x:Class="LiftProject.Views.WorkoutView"
             x:DataType="vm:WorkoutViewModel">
    
    <Grid>
        <TextBlock Text="Bienvenue sur le workout !" 
                   FontSize="24" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>


        <StackPanel>    
            <Button Content =" Start To Workout" Command="{Binding StartWorkoutCommand}"></Button>   
                 
        </StackPanel>
    </Grid>

</UserControl>