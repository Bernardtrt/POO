<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:Lab5.Views"
        
        x:DataType="views:Exercice"
        
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="Lab5.Views.ExerciceDetailWindow"
        Title="Détails de l'exercice" Width="400" Height="500" Background="#1A1A1A">

    <StackPanel Spacing="20" Margin="20">
        
        <TextBlock Text="{Binding Name}" 
                   FontSize="26" FontWeight="Bold" Foreground="#569CFF" 
                   HorizontalAlignment="Center" />

        <Image Source="{Binding Image}" Height="200" Stretch="Uniform" />

        <TextBlock Text="{Binding Description}" 
                   FontSize="16" Foreground="LightGray" 
                   TextWrapping="Wrap" />
                   

            <Button x:Name="Home" Click="GetBackHome_Click" Content="Home" HorizontalAlignment="Center" Background="#569CFF"/>

    </StackPanel>



</Window>